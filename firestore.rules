rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function role() { return userDoc().role; }
    function isAdmin() { return signedIn() && role() == 'admin'; }
    function isOwner() { return signedIn() && request.resource.data.userId == request.auth.uid; }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
      match /devices/{deviceId} { allow read, write: if signedIn() && request.auth.uid == userId; }
    }

    match /operations/{operationId} {
      allow read: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if signedIn() && isOwner();
      allow update: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if false;
    }
  }
}
